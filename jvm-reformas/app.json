{
  "expo": {
    "name": "JVM Reformas",
    "slug": "jvm-reformas",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.jvmreformas.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.jvmreformas.app"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para anexar comprovantes, notas fiscais e imagens da obra.",
          "cameraPermission": "O app precisa acessar a câmera para registrar fotos da obra e documentos."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "9a6d52af-6d34-46f9-bb07-840987ef1e6b"
      }
    },
    "owner": "fxlcaovinii"
  }
}
